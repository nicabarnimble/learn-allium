-- allium: 3
-- library-starter.allium — Lesson 01 starter

-- Scope: one library book can be borrowed and returned at a desk.
-- Includes:
--   - borrowing an available book
--   - refusing an already-borrowed book
--   - returning a borrowed book
-- Excludes:
--   - reservations, fines, holds, renewals, accounts, and inventory storage

entity Member {
    name: String
}

entity Book {
    status: on_shelf | borrowed
    title: String
    borrowed_by: String?
    due_at: Timestamp?

    is_available: status = on_shelf
}

config {
    loan_period: Duration = 21.days
}

given {
    book: Book
    member: Member
}

-- TODO: Add rule BorrowBook here.
-- It should listen for MemberBorrowsBook(member), require the book to be on_shelf,
-- move the book to borrowed, attribute it to member.name, set due_at, and emit BookBorrowed.

rule BorrowRefusedWhenTaken {
    when: MemberBorrowsBook(member)
    requires: not book.is_available
    ensures: BorrowRefused(book: book, member: member, reason: "not-on-shelf")
}

rule ReturnBook {
    when: MemberReturnsBook(member)
    requires: book.status = borrowed
    ensures: book.status = on_shelf
    ensures: book.borrowed_by = none
    ensures: book.due_at = none
    ensures: BookReturned(book: book, member: member)
}

surface LibraryDesk {
    facing member: Member
    context book: Book

    exposes:
        member.name
        book.status
        book.title
        book.due_at

    provides:
        MemberBorrowsBook(member)
        MemberReturnsBook(member)
            when book.status = borrowed
}

contract LendingPromise {
    @invariant OneBorrowerAtATime
        -- A borrowed book is attributed to exactly one member until returned.

    @invariant RefusalIsExplicit
        -- Borrowing an unavailable book produces a refusal event, not silence.
}
