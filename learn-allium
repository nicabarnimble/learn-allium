#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TUTOR="$ROOT/scripts/allium-tutor"

# Friendly default:
#   ./learn-allium          -> start Alliumlings (Rustlings-style training)
#   ./learn-allium --strict -> same, with isolated Pi auth/settings
# Advanced pass-through:
#   ./learn-allium doctor
#   ./learn-allium lesson-01 --smoke
if [[ $# -eq 0 || "${1:-}" == --* ]]; then
  exec "$TUTOR" start "$@"
fi

exec "$TUTOR" "$@"
